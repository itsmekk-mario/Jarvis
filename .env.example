OPENAI_API_KEY=your_openai_api_key
TAVILY_API_KEY=your_tavily_api_key

OLLAMA_MODEL=qwen3:4b
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_TIMEOUT=240
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=384
JARVIS_DEFAULT_LOCATION=Seoul
JARVIS_FILE_SEARCH_ROOTS=~
JARVIS_FILE_SEARCH_MAX_RESULTS=12
JARVIS_FILE_SEARCH_MAX_FILES=8000

# Optional settings
OPENAI_MODEL=gpt-4o-mini
VOICE_INPUT_ENGINE=speech_recognition
TTS_ENGINE=gtts

# Google OAuth files
GOOGLE_CLIENT_SECRET_FILE=credentials.json
GOOGLE_TOKEN_FILE=token.json

# Safety switch. Keep false unless you really want voice-triggered email sending.
JARVIS_ALLOW_EMAIL_SEND=false
